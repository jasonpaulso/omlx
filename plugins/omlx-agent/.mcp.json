{
  "mcpServers": {
    "omlx": {
      "command": "uv",
      "args": [
        "run",
        "--with", "mcp",
        "--with", "httpx",
        "python",
        "${CLAUDE_PLUGIN_ROOT}/mcp/omlx_mcp_server.py"
      ],
      "env": {
        "OMLX_BASE_URL": "${OMLX_BASE_URL}",
        "OMLX_API_KEY": "${OMLX_API_KEY}"
      }
    }
  }
}
